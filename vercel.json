{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --no-cache",
  "buildCommand": "npm run build",
  "env": {
    "VERCEL_FORCE_NO_BUILD_CACHE": "1",
    "TURBO_FORCE": "true",
    "NPM_CONFIG_CACHE": "/tmp/.npm"
  },
  "build": {
    "env": {
      "VERCEL_FORCE_NO_BUILD_CACHE": "1"
    }
  },
  "functions": {
    "app/api/mint-vip/route.ts": {
      "maxDuration": 60
    },
    "app/api/stripe-webhook/route.ts": {
      "maxDuration": 60
    },
    "app/api/admin/mint-contributor/route.ts": {
      "maxDuration": 60
    },
    "app/api/admin/mint-premium/route.ts": {
      "maxDuration": 60
    },
    "app/api/check-membership/route.ts": {
      "maxDuration": 30
    },
    "app/api/agent/execute-purchase/route.ts": {
      "maxDuration": 300
    },
    "app/api/agent/fulfill-merch/route.ts": {
      "maxDuration": 300
    },
    "app/api/agent/send-usdc/route.ts": {
      "maxDuration": 120
    },
    "app/api/cron/check-proposals/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/distribute-pool/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/allocate-allowances/route.ts": {
      "maxDuration": 300
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/reset-budgets",
      "schedule": "0 0 * * 1"
    },
    {
      "path": "/api/cron/distribute-pool",
      "schedule": "0 0 * * 0"
    },
    {
      "path": "/api/cron/allocate-allowances",
      "schedule": "0 0 * * 0"
    },
    {
      "path": "/api/cron/check-proposals",
      "schedule": "*/5 * * * *"
    }
  ]
}
